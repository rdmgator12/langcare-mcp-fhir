# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test
CLAUDE.md
CLAUDE-original.md
CLAUDE*.md
.claude/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dev keys and credentials (NEVER COMMIT!)
*.pem
jwks.json
keys/
config.local.yaml
configs/config.local.*.yaml
*-credentials.yaml

# CMA generated state (contains API IDs, regenerated by setup.sh)
cma/skills-registry.json
cma/.setup-state-*.json

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

scractchpad.txt

bin/
node_modules/

# MCP Apps build artifacts
apps/dist/
apps/dist-tmp/
apps/node_modules/
internal/apps/dist/*.html
!internal/apps/dist/.gitkeep.html

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/.mcpregistry_*

.mcpregistry_github_token
.mcpregistry_registry_token
